# ------------------------
# Airflow (MLOps)
# ------------------------
# Ignore the local SQLite database
MLOps/Airflow/airflow.db

# Ignore all logs generated by runs
MLOps/Airflow/logs/

# Ignore configuration files (these can contain secret keys/passwords)
MLOps/Airflow/airflow.cfg
MLOps/Airflow/webserver_config.py

# Ignore process ID files (temporary system files)
MLOps/Airflow/*.pid

# Ignore the isolated venv you created for Airflow
MLOps/Airflow/.venv_airflow/